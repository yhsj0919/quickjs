{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quickjs-ui.local/quickjs_ui.schema.json",
  "title": "quickjs_ui UI schema",
  "description": "Serializable UI node schema rendered by package:quickjs_ui.",
  "$ref": "#/$defs/node",
  "$defs": {
    "jsonValue": {
      "oneOf": [
        { "type": "null" },
        { "type": "boolean" },
        { "type": "number" },
        { "type": "string" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/jsonValue" }
        },
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/jsonValue" }
        }
      ]
    },
    "event": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/jsonValue" },
      "properties": {
        "action": { "type": "string" },
        "method": { "type": "string" },
        "payload": { "$ref": "#/$defs/jsonValue" },
        "source": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "anyOf": [
        { "required": ["action"] },
        { "required": ["method"] }
      ]
    },
    "node": {
      "oneOf": [
        { "$ref": "#/$defs/text" },
        { "$ref": "#/$defs/elevatedButton" },
        { "$ref": "#/$defs/row" },
        { "$ref": "#/$defs/column" },
        { "$ref": "#/$defs/container" },
        { "$ref": "#/$defs/image" },
        { "$ref": "#/$defs/listView" },
        { "$ref": "#/$defs/textField" },
        { "$ref": "#/$defs/stack" },
        { "$ref": "#/$defs/padding" },
        { "$ref": "#/$defs/center" },
        { "$ref": "#/$defs/sizedBox" }
      ]
    },
    "baseNode": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": { "$ref": "#/$defs/jsonValue" },
      "properties": {
        "type": { "type": "string" },
        "key": { "type": "string" },
        "child": { "$ref": "#/$defs/node" },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/node" }
        }
      },
      "not": {
        "required": ["child", "children"]
      }
    },
    "edgeInsets": {
      "oneOf": [
        { "type": "number" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "all": { "type": "number" },
            "value": { "type": "number" },
            "left": { "type": "number" },
            "top": { "type": "number" },
            "right": { "type": "number" },
            "bottom": { "type": "number" },
            "horizontal": { "type": "number" },
            "vertical": { "type": "number" }
          }
        }
      ]
    },
    "borderRadius": {
      "oneOf": [
        { "type": "number" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "all": { "type": "number" },
            "radius": { "type": "number" },
            "topLeft": { "type": "number" },
            "topRight": { "type": "number" },
            "bottomLeft": { "type": "number" },
            "bottomRight": { "type": "number" }
          }
        }
      ]
    },
    "color": {
      "oneOf": [
        { "type": "number" },
        {
          "type": "string",
          "pattern": "^(#|0x|0X)?[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$"
        },
        {
          "type": "string",
          "pattern": "^\\$(theme\\.|color\\.|colors\\.)?[A-Za-z][A-Za-z0-9.]*$"
        }
      ]
    },
    "textStyle": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^\\$(text\\.|textTheme\\.)?[A-Za-z][A-Za-z0-9.]*$"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "color": { "$ref": "#/$defs/color" },
            "fontSize": { "type": "number" },
            "fontWeight": {
              "oneOf": [
                { "type": "number", "enum": [100, 200, 300, 400, 500, 600, 700, 800, 900] },
                {
                  "type": "string",
                  "enum": ["normal", "bold", "w100", "w200", "w300", "w400", "w500", "w600", "w700", "w800", "w900"]
                }
              ]
            },
            "letterSpacing": { "type": "number" },
            "height": { "type": "number" }
          }
        }
      ]
    },
    "boxDecoration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "color": { "$ref": "#/$defs/color" },
        "borderRadius": { "$ref": "#/$defs/borderRadius" },
        "border": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "color": { "$ref": "#/$defs/color" },
            "width": { "type": "number" }
          }
        }
      }
    },
    "singleChild": {
      "type": "object",
      "properties": {
        "child": { "$ref": "#/$defs/node" }
      }
    },
    "multiChild": {
      "type": "object",
      "properties": {
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/node" }
        }
      }
    },
    "text": {
      "allOf": [
        { "$ref": "#/$defs/baseNode" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "Text" },
            "data": { "type": "string" },
            "text": { "type": "string" },
            "textAlign": {
              "type": "string",
              "enum": ["left", "right", "center", "justify", "start", "end"]
            },
            "style": { "$ref": "#/$defs/textStyle" }
          }
        }
      ]
    },
    "elevatedButton": {
      "allOf": [
        { "$ref": "#/$defs/baseNode" },
        { "$ref": "#/$defs/singleChild" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "ElevatedButton" },
            "onPressed": { "$ref": "#/$defs/event" }
          }
        }
      ]
    },
    "flex": {
      "allOf": [
        { "$ref": "#/$defs/multiChild" },
        {
          "type": "object",
          "properties": {
            "mainAxisAlignment": {
              "type": "string",
              "enum": ["start", "end", "center", "spaceBetween", "spaceAround", "spaceEvenly"]
            },
            "crossAxisAlignment": {
              "type": "string",
              "enum": ["start", "end", "center", "stretch", "baseline"]
            }
          }
        }
      ]
    },
    "row": {
      "allOf": [
        { "$ref": "#/$defs/baseNode" },
        { "$ref": "#/$defs/flex" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "Row" }
          }
        }
      ]
    },
    "column": {
      "allOf": [
        { "$ref": "#/$defs/baseNode" },
        { "$ref": "#/$defs/flex" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "Column" }
          }
        }
      ]
    },
    "container": {
      "allOf": [
        { "$ref": "#/$defs/baseNode" },
        { "$ref": "#/$defs/singleChild" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "Container" },
            "width": { "type": "number" },
            "height": { "type": "number" },
            "padding": { "$ref": "#/$defs/edgeInsets" },
            "margin": { "$ref": "#/$defs/edgeInsets" },
            "alignment": {
              "type": "string",
              "enum": ["topLeft", "topCenter", "topRight", "centerLeft", "center", "centerRight", "bottomLeft", "bottomCenter", "bottomRight"]
            },
            "color": { "$ref": "#/$defs/color" },
            "backgroundColor": { "$ref": "#/$defs/color" },
            "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
            "decoration": { "$ref": "#/$defs/boxDecoration" },
            "borderRadius": { "$ref": "#/$defs/borderRadius" },
            "borderColor": { "$ref": "#/$defs/color" },
            "borderWidth": { "type": "number" }
          }
        }
      ]
    },
    "image": {
      "allOf": [
        { "$ref": "#/$defs/baseNode" },
        {
          "type": "object",
          "anyOf": [
            { "required": ["src"] },
            { "required": ["source"] }
          ],
          "properties": {
            "type": { "const": "Image" },
            "src": { "type": "string", "minLength": 1 },
            "source": { "type": "string", "minLength": 1 },
            "width": { "type": "number" },
            "height": { "type": "number" },
            "fit": {
              "type": "string",
              "enum": ["fill", "contain", "cover", "fitWidth", "fitHeight", "none", "scaleDown"]
            }
          }
        }
      ]
    },
    "listView": {
      "allOf": [
        { "$ref": "#/$defs/baseNode" },
        { "$ref": "#/$defs/multiChild" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "ListView" },
            "scrollDirection": { "type": "string", "enum": ["vertical", "horizontal"] },
            "shrinkWrap": { "type": "boolean" },
            "padding": { "$ref": "#/$defs/edgeInsets" }
          }
        }
      ]
    },
    "textField": {
      "allOf": [
        { "$ref": "#/$defs/baseNode" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "TextField" },
            "value": { "type": "string" },
            "initialValue": { "type": "string" },
            "labelText": { "type": "string" },
            "hintText": { "type": "string" },
            "enabled": { "type": "boolean" },
            "autofocus": { "type": "boolean" },
            "obscureText": { "type": "boolean" },
            "maxLines": { "type": "integer", "minimum": 1 },
            "keyboardType": {
              "type": "string",
              "enum": ["text", "multiline", "number", "phone", "datetime", "emailAddress", "url", "visiblePassword"]
            },
            "textInputAction": {
              "type": "string",
              "enum": ["none", "unspecified", "done", "go", "search", "send", "next", "previous", "continueAction", "join", "route", "emergencyCall", "newline"]
            },
            "onChanged": { "$ref": "#/$defs/event" },
            "onSubmitted": { "$ref": "#/$defs/event" },
            "onFocus": { "$ref": "#/$defs/event" },
            "onBlur": { "$ref": "#/$defs/event" }
          }
        }
      ]
    },
    "stack": {
      "allOf": [
        { "$ref": "#/$defs/baseNode" },
        { "$ref": "#/$defs/multiChild" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "Stack" },
            "alignment": {
              "type": "string",
              "enum": ["topLeft", "topCenter", "topRight", "centerLeft", "center", "centerRight", "bottomLeft", "bottomCenter", "bottomRight"]
            },
            "fit": { "type": "string", "enum": ["loose", "expand", "passthrough"] }
          }
        }
      ]
    },
    "padding": {
      "allOf": [
        { "$ref": "#/$defs/baseNode" },
        { "$ref": "#/$defs/singleChild" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "Padding" },
            "padding": { "$ref": "#/$defs/edgeInsets" }
          }
        }
      ]
    },
    "center": {
      "allOf": [
        { "$ref": "#/$defs/baseNode" },
        { "$ref": "#/$defs/singleChild" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "Center" },
            "widthFactor": { "type": "number" },
            "heightFactor": { "type": "number" }
          }
        }
      ]
    },
    "sizedBox": {
      "allOf": [
        { "$ref": "#/$defs/baseNode" },
        { "$ref": "#/$defs/singleChild" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "SizedBox" },
            "width": { "type": "number" },
            "height": { "type": "number" }
          }
        }
      ]
    }
  }
}
